# Templated — REGION substituted at apply time. Token comes from Vault on LZ via
# `kubectl get secret demo-token -n demo-nats-kv` (LZ ns), copied here.
apiVersion: v1
kind: Secret
metadata:
  name: kv-config
  namespace: demo-nats-kv
type: Opaque
stringData:
  region: "REGION"
  demo_token: "TOKEN"
